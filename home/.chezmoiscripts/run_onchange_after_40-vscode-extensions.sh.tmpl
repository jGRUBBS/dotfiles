#!/usr/bin/env bash

# Extension manifest checksum: {{ include ".chezmoitemplates/data/vscode-extensions.txt" | sha256sum }}
set -euo pipefail

if ! command -v code >/dev/null 2>&1; then
  printf 'VS Code CLI is unavailable; skipping extensions.\n' >&2
  exit 0
fi

manifest={{ joinPath .chezmoi.sourceDir ".chezmoitemplates/data/vscode-extensions.txt" | quote }}
installed="$(mktemp)"
trap 'rm -f "${installed}"' EXIT
code --list-extensions | tr '[:upper:]' '[:lower:]' | sort -u > "${installed}"

while IFS= read -r extension; do
  [[ -z "${extension}" || "${extension}" == \#* ]] && continue
  if ! grep -Fqx "$(printf '%s' "${extension}" | tr '[:upper:]' '[:lower:]')" "${installed}"; then
    code --install-extension "${extension}"
  fi
done < "${manifest}"
