#!/usr/bin/env bash

# Brewfile checksum: {{ include ".chezmoitemplates/data/Brewfile" | sha256sum }}
set -euo pipefail

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
else
  printf 'Homebrew is unavailable after installation.\n' >&2
  exit 1
fi

brew bundle install \
  --file={{ joinPath .chezmoi.sourceDir ".chezmoitemplates/data/Brewfile" | quote }} \
  --no-upgrade
