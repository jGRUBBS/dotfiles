#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: dotfiles COMMAND

Commands:
  apply               Apply the checked-out configuration
  diff                Preview configuration drift
  sync                Fast-forward Git, preview, and apply
  doctor              Validate this Mac's setup
  secrets bootstrap   Save a BWS access token in macOS Keychain
  secrets test        Verify Bitwarden Secrets Manager access
  aws sync            Install AWS credentials from Bitwarden
  composer sync       Install Composer auth from Bitwarden
  composer check      Validate Composer config and auth
  ssh sync            Install selected SSH keys from Bitwarden
  ssh check           Validate managed SSH keys and permissions
  vscode-extensions   Refresh the tracked VS Code extension manifest
EOF
}

source_repo() {
  local source
  source="$(chezmoi source-path)"
  git -C "${source}" rev-parse --show-toplevel 2>/dev/null ||
    git -C "${source}/.." rev-parse --show-toplevel
}

bootstrap_secrets() {
  local token
  printf 'Paste the replacement BWS machine-account token: ' >&2
  IFS= read -r -s token
  printf '\n' >&2
  if [[ -z "${token}" ]]; then
    printf 'No token supplied.\n' >&2
    exit 1
  fi

  security add-generic-password \
    -U \
    -a "${USER}" \
    -s dotfiles-bws-access-token \
    -w "${token}" >/dev/null
  unset token
  printf 'Stored the BWS token in macOS Keychain.\n'
}

test_secrets() {
  local token
  if ! command -v bws >/dev/null 2>&1; then
    printf 'bws is not installed; run dotfiles apply.\n' >&2
    exit 1
  fi

  token="$(security find-generic-password \
    -a "${USER}" \
    -s dotfiles-bws-access-token \
    -w 2>/dev/null || true)"
  if [[ -z "${token}" ]]; then
    printf 'No BWS token is stored; run dotfiles secrets bootstrap.\n' >&2
    exit 1
  fi

  BWS_ACCESS_TOKEN="${token}" bws secret list >/dev/null
  unset token
  printf 'Bitwarden Secrets Manager access is working.\n'
}

sync_dotfiles() {
  local repo answer
  repo="$(source_repo)"
  if [[ -n "$(git -C "${repo}" status --porcelain)" ]]; then
    printf 'The dotfiles source has uncommitted changes; refusing to pull.\n' >&2
    git -C "${repo}" status --short >&2
    exit 1
  fi
  if ! git -C "${repo}" rev-parse --abbrev-ref '@{upstream}' >/dev/null 2>&1; then
    printf 'The current dotfiles branch has no upstream.\n' >&2
    exit 1
  fi

  git -C "${repo}" fetch --prune
  git -C "${repo}" merge --ff-only '@{upstream}'
  chezmoi diff || true

  if [[ "${DOTFILES_ASSUME_YES:-0}" != "1" ]]; then
    printf 'Apply these changes? [y/N] ' >&2
    IFS= read -r answer
    [[ "${answer}" =~ ^[Yy]$ ]] || exit 0
  fi
  chezmoi apply --verbose
}

refresh_vscode_extensions() {
  local repo manifest
  command -v code >/dev/null 2>&1 || {
    printf 'The VS Code CLI is not installed.\n' >&2
    exit 1
  }
  repo="$(source_repo)"
  manifest="${repo}/home/.chezmoitemplates/data/vscode-extensions.txt"
  code --list-extensions | tr '[:upper:]' '[:lower:]' | sort -u > "${manifest}"
  printf 'Updated %s\n' "${manifest}"
}

case "${1:-}" in
  apply)
    chezmoi apply --verbose
    ;;
  diff)
    chezmoi diff
    ;;
  sync)
    sync_dotfiles
    ;;
  doctor)
    repo="$(source_repo)"
    "${repo}/scripts/doctor.sh"
    ;;
  secrets)
    case "${2:-}" in
      bootstrap) bootstrap_secrets ;;
      test) test_secrets ;;
      *) usage; exit 2 ;;
    esac
    ;;
  aws)
    case "${2:-}" in
      sync) "${HOME}/.local/bin/dotfiles-aws-sync" ;;
      *) usage; exit 2 ;;
    esac
    ;;
  composer)
    case "${2:-}" in
      sync) "${HOME}/.local/bin/dotfiles-composer-sync" ;;
      check) "${HOME}/.local/bin/dotfiles-composer-sync" --check ;;
      *) usage; exit 2 ;;
    esac
    ;;
  ssh)
    case "${2:-}" in
      sync) "${HOME}/.local/bin/dotfiles-ssh-sync" ;;
      check) "${HOME}/.local/bin/dotfiles-ssh-sync" --check ;;
      *) usage; exit 2 ;;
    esac
    ;;
  vscode-extensions)
    refresh_vscode_extensions
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
