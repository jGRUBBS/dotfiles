#!/usr/bin/env bash

set -euo pipefail

usage() {
  printf 'Usage: dotfiles-secret SECRET_NAME\n' >&2
  exit 2
}

[[ "$#" -eq 1 ]] || usage
secret_name="$1"

case "${secret_name}" in
  SUCURI_API_KEY|\
  SUCURI_APP_KEY_CHARLESTONPLACE_COM|\
  SUCURI_APP_KEY_AMERICANGARDENSCHS_COM|\
  SUCURI_APP_KEY_THECOOPER_COM|\
  BROWSERSTACK_USERNAME|\
  BROWSERSTACK_ACCESS_KEY)
    ;;
  *)
    printf 'Secret is not allowlisted: %s\n' "${secret_name}" >&2
    exit 1
    ;;
esac

if ! command -v bws >/dev/null 2>&1; then
  printf 'bws is not installed; run dotfiles apply.\n' >&2
  exit 1
fi

token="$(security find-generic-password \
  -a "${USER}" \
  -s dotfiles-bws-access-token \
  -w 2>/dev/null || true)"
if [[ -z "${token}" ]]; then
  printf 'No BWS token is stored; run dotfiles secrets bootstrap.\n' >&2
  exit 1
fi

BWS_ACCESS_TOKEN="${token}" bws secret list |
  jq -er --arg key "${secret_name}" \
    'first(.[] | select(.key == $key) | .value)'
