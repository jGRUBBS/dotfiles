#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v chezmoi >/dev/null 2>&1; then
  install_dir="${HOME}/.local/bin"
  mkdir -p "${install_dir}"
  sh -c "$(curl -fsLS https://get.chezmoi.io)" -- -b "${install_dir}"
  export PATH="${install_dir}:${PATH}"
fi

active_source="$(chezmoi source-path 2>/dev/null || true)"
active_repo="$(
  git -C "${active_source:-/nonexistent}" rev-parse --show-toplevel 2>/dev/null ||
    true
)"
if [[ "${active_repo}" != "${repo_root}" ]]; then
  chezmoi init --source "${repo_root}" --apply --verbose
else
  chezmoi apply --verbose
fi
